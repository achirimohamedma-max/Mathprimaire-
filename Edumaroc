<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مدرستي عن بُعد – ابتدائي</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --royal-blue: #1A3A6B;
    --sky: #2B7EC1;
    --sky-light: #4FA3D8;
    --emerald: #1D7A5F;
    --emerald-light: #2BA580;
    --gold: #C8942A;
    --gold-light: #E8B84B;
    --cream: #F8F5EF;
    --white: #FFFFFF;
    --gray-soft: #EEF2F7;
    --gray-mid: #B0BEC5;
    --gray-dark: #546E7A;
    --text-main: #1C2B3A;
    --text-soft: #4A6278;
    --red-alert: #C0392B;
    --purple-sub: #6C3D9E;
    --orange-warm: #D4521A;
    --shadow-soft: 0 4px 20px rgba(26,58,107,0.10);
    --shadow-card: 0 2px 12px rgba(26,58,107,0.08);
    --radius-xl: 20px;
    --radius-lg: 14px;
    --radius-md: 10px;
    --radius-sm: 6px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Cairo', 'Tajawal', sans-serif;
    background: var(--cream);
    color: var(--text-main);
    direction: rtl;
    min-height: 100vh;
  }

  /* ─── NAVIGATION ─── */
  .nav-bar {
    position: fixed; top: 0; right: 0; left: 0; z-index: 100;
    background: var(--royal-blue);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 20px; height: 58px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.18);
  }
  .nav-logo { display: flex; align-items: center; gap: 10px; }
  .nav-logo img { width: 36px; height: 36px; object-fit: contain; }
  .nav-logo-text { color: var(--white); font-size: 14px; font-weight: 700; line-height: 1.3; }
  .nav-logo-text span { display: block; font-size: 11px; font-weight: 400; opacity: 0.8; }
  .nav-actions { display: flex; align-items: center; gap: 10px; }
  .nav-btn {
    background: rgba(255,255,255,0.15); border: none; color: white;
    padding: 6px 14px; border-radius: 20px; font-size: 13px; font-family: inherit;
    cursor: pointer; transition: background 0.2s;
    display: flex; align-items: center; gap: 6px;
  }
  .nav-btn:hover { background: rgba(255,255,255,0.25); }
  .nav-btn.active-screen { background: var(--gold); color: var(--royal-blue); font-weight: 700; }

  /* ─── SCREEN SWITCHER ─── */
  .screen { display: none; padding-top: 58px; min-height: 100vh; }
  .screen.active { display: block; }

  /* ══════════════════════════════════════
     SCREEN 1 – SPLASH / WELCOME
  ══════════════════════════════════════ */
  #screen-splash {
    background: linear-gradient(160deg, var(--royal-blue) 0%, #0e2550 55%, #1D7A5F 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    min-height: 100vh; padding: 60px 24px 40px; text-align: center;
    position: relative; overflow: hidden;
  }
  #screen-splash .bg-circles::before,
  #screen-splash .bg-circles::after {
    content: ''; position: absolute; border-radius: 50%;
    background: rgba(255,255,255,0.04);
  }
  #screen-splash .bg-circles::before { width: 420px; height: 420px; top: -100px; left: -160px; }
  #screen-splash .bg-circles::after  { width: 300px; height: 300px; bottom: -80px; right: -80px; }

  .splash-ministry-badge {
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 30px; padding: 8px 20px; margin-bottom: 32px;
    color: rgba(255,255,255,0.9); font-size: 12px; letter-spacing: 0.5px;
  }
  .splash-emblem {
    width: 90px; height: 90px; background: var(--white);
    border-radius: 50%; margin: 0 auto 20px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    font-size: 42px;
  }
  .splash-title {
    color: var(--white); font-size: 30px; font-weight: 900; line-height: 1.3;
    margin-bottom: 8px; text-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .splash-subtitle {
    color: var(--gold-light); font-size: 15px; font-weight: 600; margin-bottom: 10px;
  }
  .splash-desc {
    color: rgba(255,255,255,0.75); font-size: 14px; max-width: 340px; margin: 0 auto 40px;
    line-height: 1.7;
  }
  .splash-levels {
    display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-bottom: 36px;
  }
  .splash-level-badge {
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
    color: white; border-radius: 20px; padding: 6px 16px; font-size: 13px; font-weight: 600;
  }
  .splash-cta {
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    color: var(--royal-blue); border: none; padding: 16px 48px;
    border-radius: 50px; font-size: 17px; font-weight: 800; font-family: inherit;
    cursor: pointer; box-shadow: 0 8px 24px rgba(200,148,42,0.45);
    transition: transform 0.2s, box-shadow 0.2s; margin-bottom: 16px;
  }
  .splash-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(200,148,42,0.55); }
  .splash-footer {
    color: rgba(255,255,255,0.5); font-size: 11px; margin-top: 12px;
    display: flex; align-items: center; gap: 6px;
  }

  /* ══════════════════════════════════════
     SCREEN 2 – LOGIN
  ══════════════════════════════════════ */
  #screen-login {
    background: linear-gradient(180deg, #EEF4FB 0%, var(--cream) 100%);
    min-height: 100vh; padding: 80px 24px 40px; display: flex; flex-direction: column;
  }
  .login-header { text-align: center; margin-bottom: 32px; }
  .login-header .login-icon {
    width: 72px; height: 72px; background: linear-gradient(135deg, var(--royal-blue), var(--sky));
    border-radius: 50%; margin: 0 auto 16px; display: flex; align-items: center;
    justify-content: center; font-size: 32px; box-shadow: var(--shadow-soft);
  }
  .login-header h2 { font-size: 22px; font-weight: 800; color: var(--royal-blue); margin-bottom: 6px; }
  .login-header p  { color: var(--text-soft); font-size: 14px; }

  .login-card {
    background: white; border-radius: var(--radius-xl); padding: 28px 24px;
    box-shadow: var(--shadow-soft); max-width: 420px; width: 100%; margin: 0 auto;
  }
  .login-tabs { display: flex; border-radius: var(--radius-md); overflow: hidden; margin-bottom: 24px; background: var(--gray-soft); }
  .login-tab {
    flex: 1; padding: 10px; text-align: center; font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all 0.2s; color: var(--text-soft); border: none; background: transparent; font-family: inherit;
  }
  .login-tab.active { background: var(--royal-blue); color: white; border-radius: var(--radius-md); }

  .form-group { margin-bottom: 18px; }
  .form-label { font-size: 13px; font-weight: 700; color: var(--text-main); margin-bottom: 7px; display: block; }
  .form-input {
    width: 100%; padding: 13px 16px; border: 2px solid #DDE4ED; border-radius: var(--radius-md);
    font-size: 15px; font-family: inherit; color: var(--text-main); background: var(--gray-soft);
    transition: border-color 0.2s; outline: none; direction: rtl;
  }
  .form-input:focus { border-color: var(--sky); background: white; }
  .form-hint { font-size: 11px; color: var(--text-soft); margin-top: 4px; }

  .login-btn {
    width: 100%; padding: 15px; background: linear-gradient(135deg, var(--royal-blue), var(--sky));
    color: white; border: none; border-radius: var(--radius-md); font-size: 16px;
    font-weight: 800; font-family: inherit; cursor: pointer; margin-top: 8px;
    box-shadow: 0 6px 20px rgba(26,58,107,0.35); transition: transform 0.2s;
  }
  .login-btn:hover { transform: translateY(-1px); }

  .login-divider { text-align: center; margin: 16px 0; color: var(--gray-mid); font-size: 13px; }
  .parent-link {
    display: block; text-align: center; color: var(--sky); font-size: 13px;
    font-weight: 600; text-decoration: none; padding: 10px;
  }
  .security-note {
    display: flex; align-items: center; gap: 8px; background: #E8F5E9;
    border-radius: var(--radius-md); padding: 10px 14px; margin-top: 16px;
    font-size: 12px; color: var(--emerald);
  }

  /* ══════════════════════════════════════
     SCREEN 3 – LEVEL SELECTION
  ══════════════════════════════════════ */
  #screen-levels { background: var(--cream); padding-top: 80px; }
  .levels-header {
    background: linear-gradient(135deg, var(--royal-blue), var(--sky));
    padding: 28px 24px; text-align: center; color: white;
  }
  .levels-header h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
  .levels-header p  { font-size: 14px; opacity: 0.85; }
  .levels-grid { padding: 28px 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 480px; margin: 0 auto; }
  .level-card {
    background: white; border-radius: var(--radius-xl); padding: 24px 16px;
    text-align: center; box-shadow: var(--shadow-card); cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s; border: 3px solid transparent;
    position: relative; overflow: hidden;
  }
  .level-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-soft); }
  .level-card.selected { border-color: var(--sky); }
  .level-card .level-num {
    font-size: 38px; font-weight: 900; margin-bottom: 6px;
  }
  .level-card .level-name { font-size: 14px; font-weight: 700; color: var(--text-main); margin-bottom: 4px; }
  .level-card .level-age  { font-size: 12px; color: var(--text-soft); }
  .level-card .level-stripe {
    position: absolute; top: 0; right: 0; left: 0; height: 5px; border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }
  .lc-1 .level-stripe { background: #E74C3C; } .lc-1 .level-num { color: #E74C3C; }
  .lc-2 .level-stripe { background: #E67E22; } .lc-2 .level-num { color: #E67E22; }
  .lc-3 .level-stripe { background: #F1C40F; } .lc-3 .level-num { color: #C8942A; }
  .lc-4 .level-stripe { background: #2ECC71; } .lc-4 .level-num { color: #27AE60; }
  .lc-5 .level-stripe { background: #3498DB; } .lc-5 .level-num { color: #2980B9; }
  .lc-6 .level-stripe { background: #9B59B6; } .lc-6 .level-num { color: #8E44AD; }
  .levels-confirm-btn {
    display: block; margin: 8px 20px 32px; padding: 16px;
    background: linear-gradient(135deg, var(--emerald), var(--emerald-light));
    color: white; border: none; border-radius: var(--radius-md); font-size: 16px;
    font-weight: 800; font-family: inherit; cursor: pointer; max-width: 440px;
    box-shadow: 0 6px 20px rgba(29,122,95,0.35); transition: transform 0.2s; width: calc(100% - 40px);
  }
  .levels-confirm-btn:hover { transform: translateY(-1px); }

  /* ══════════════════════════════════════
     SCREEN 4 – STUDENT HOME
  ══════════════════════════════════════ */
  #screen-home { background: #EDF3FA; }
  .home-hero {
    background: linear-gradient(135deg, var(--royal-blue) 0%, #1a5276 60%, var(--sky) 100%);
    padding: 24px 20px 36px; position: relative; overflow: hidden;
  }
  .home-hero::after {
    content: ''; position: absolute; bottom: -18px; right: 0; left: 0;
    height: 36px; background: #EDF3FA; border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }
  .home-hero-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
  .home-greeting { color: white; }
  .home-greeting .hello { font-size: 14px; opacity: 0.85; margin-bottom: 2px; }
  .home-greeting .name  { font-size: 22px; font-weight: 900; }
  .home-avatar {
    width: 52px; height: 52px; border-radius: 50%; background: var(--gold-light);
    display: flex; align-items: center; justify-content: center; font-size: 24px;
    border: 3px solid rgba(255,255,255,0.4);
  }
  .home-info-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .home-badge {
    background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3);
    color: white; border-radius: 20px; padding: 5px 14px; font-size: 12px; font-weight: 600;
  }

  .progress-section { padding: 24px 20px 8px; }
  .progress-title { font-size: 14px; font-weight: 700; color: var(--text-main); margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
  .progress-title span { color: var(--sky); font-size: 13px; font-weight: 600; }
  .progress-bar-wrap { background: white; border-radius: var(--radius-lg); padding: 14px 18px; box-shadow: var(--shadow-card); }
  .progress-bar-label { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 12px; color: var(--text-soft); }
  .progress-bar-bg { background: var(--gray-soft); border-radius: 20px; height: 10px; overflow: hidden; }
  .progress-bar-fill { height: 100%; border-radius: 20px; background: linear-gradient(90deg, var(--emerald), var(--emerald-light)); width: 62%; transition: width 1s; }
  .progress-stars { display: flex; gap: 4px; margin-top: 10px; }
  .star { font-size: 18px; }

  .section-title { font-size: 15px; font-weight: 800; color: var(--text-main); padding: 16px 20px 10px; }
  .subjects-grid { padding: 0 16px 8px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .subject-card {
    background: white; border-radius: var(--radius-lg); padding: 16px 10px 12px;
    text-align: center; cursor: pointer; box-shadow: var(--shadow-card);
    transition: transform 0.2s, box-shadow 0.2s; border-bottom: 3px solid transparent;
  }
  .subject-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-soft); }
  .subject-icon { font-size: 28px; margin-bottom: 6px; display: block; }
  .subject-name { font-size: 12px; font-weight: 700; color: var(--text-main); line-height: 1.3; }
  .sc-arabic   { border-color: #C0392B; } .sc-arabic .subject-icon   { filter: none; }
  .sc-math     { border-color: #2980B9; }
  .sc-science  { border-color: #27AE60; }
  .sc-islamic  { border-color: #C8942A; }
  .sc-social   { border-color: #8E44AD; }
  .sc-french   { border-color: #2C3E50; }
  .sc-reading  { border-color: #E67E22; }

  .last-lesson-card {
    margin: 0 16px 8px; background: white; border-radius: var(--radius-lg);
    padding: 16px 18px; box-shadow: var(--shadow-card); cursor: pointer;
    display: flex; align-items: center; gap: 14px; transition: box-shadow 0.2s;
  }
  .last-lesson-card:hover { box-shadow: var(--shadow-soft); }
  .last-lesson-thumb {
    width: 54px; height: 54px; border-radius: var(--radius-md);
    background: linear-gradient(135deg, #C0392B, #E74C3C);
    display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0;
  }
  .last-lesson-info { flex: 1; }
  .last-lesson-subject { font-size: 11px; font-weight: 700; color: #C0392B; margin-bottom: 3px; }
  .last-lesson-title   { font-size: 14px; font-weight: 700; color: var(--text-main); margin-bottom: 4px; }
  .last-lesson-meta    { font-size: 11px; color: var(--text-soft); }
  .continue-btn {
    background: var(--royal-blue); color: white; border: none; padding: 8px 14px;
    border-radius: var(--radius-md); font-size: 12px; font-weight: 700; font-family: inherit;
    cursor: pointer; white-space: nowrap;
  }

  .quick-actions { padding: 8px 16px 80px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .quick-card {
    background: white; border-radius: var(--radius-lg); padding: 16px 14px;
    display: flex; align-items: center; gap: 12px; box-shadow: var(--shadow-card);
    cursor: pointer; transition: transform 0.2s;
  }
  .quick-card:hover { transform: translateY(-2px); }
  .quick-icon { width: 40px; height: 40px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
  .qi-schedule  { background: #EBF5FB; }
  .qi-exercises { background: #EAFAF1; }
  .qi-results   { background: #FEF9E7; }
  .qi-help      { background: #F4ECF7; }
  .quick-text .quick-label { font-size: 13px; font-weight: 700; color: var(--text-main); }
  .quick-text .quick-sub   { font-size: 11px; color: var(--text-soft); }

  /* ══════════════════════════════════════
     SCREEN 5 – SUBJECTS / LESSONS
  ══════════════════════════════════════ */
  #screen-subjects { background: #EDF3FA; }
  .subject-hero {
    background: linear-gradient(135deg, #C0392B, #E74C3C);
    padding: 24px 20px 28px; color: white;
  }
  .subject-hero-back {
    display: flex; align-items: center; gap: 8px; margin-bottom: 14px; cursor: pointer; opacity: 0.85;
    font-size: 13px; background: none; border: none; color: white; font-family: inherit;
  }
  .subject-hero-icon { font-size: 40px; margin-bottom: 8px; display: block; }
  .subject-hero h2 { font-size: 22px; font-weight: 900; margin-bottom: 4px; }
  .subject-hero p  { font-size: 13px; opacity: 0.85; }

  .units-list { padding: 16px; }
  .unit-card {
    background: white; border-radius: var(--radius-lg); margin-bottom: 12px;
    box-shadow: var(--shadow-card); overflow: hidden;
  }
  .unit-header {
    padding: 14px 18px; display: flex; align-items: center; gap: 12px; cursor: pointer;
    border-bottom: 1px solid var(--gray-soft);
  }
  .unit-num {
    width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #C0392B, #E74C3C);
    color: white; display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 800; flex-shrink: 0;
  }
  .unit-title { flex: 1; font-size: 15px; font-weight: 700; color: var(--text-main); }
  .unit-progress-pill {
    background: var(--gray-soft); border-radius: 20px; padding: 3px 10px;
    font-size: 11px; color: var(--text-soft);
  }
  .unit-progress-pill.done { background: #EAFAF1; color: var(--emerald); }
  .lessons-list { padding: 8px 14px 14px; }
  .lesson-row {
    display: flex; align-items: center; gap: 12px; padding: 10px 6px;
    border-bottom: 1px solid var(--gray-soft); cursor: pointer;
    transition: background 0.15s; border-radius: var(--radius-sm);
  }
  .lesson-row:last-child { border-bottom: none; }
  .lesson-row:hover { background: var(--gray-soft); }
  .lesson-status { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; }
  .ls-done    { background: #EAFAF1; }
  .ls-current { background: #EBF5FB; }
  .ls-locked  { background: var(--gray-soft); }
  .lesson-name { flex: 1; font-size: 13px; font-weight: 600; color: var(--text-main); }
  .lesson-name.locked { color: var(--gray-mid); }
  .lesson-type {
    font-size: 11px; padding: 3px 8px; border-radius: 10px; font-weight: 600;
  }
  .lt-video { background: #EBF5FB; color: var(--sky); }
  .lt-exercise { background: #EAFAF1; color: var(--emerald); }
  .lt-quiz { background: #FEF9E7; color: var(--gold); }

  /* ══════════════════════════════════════
     SCREEN 6 – VIDEO LESSON
  ══════════════════════════════════════ */
  #screen-video { background: #0A1525; min-height: 100vh; }
  .video-top { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; }
  .video-back-btn {
    background: rgba(255,255,255,0.1); color: white; border: none; border-radius: var(--radius-md);
    padding: 8px 14px; font-size: 13px; font-family: inherit; cursor: pointer; display: flex; align-items: center; gap: 6px;
  }
  .video-level-badge { background: var(--gold); color: var(--royal-blue); border-radius: 20px; padding: 5px 14px; font-size: 12px; font-weight: 700; }
  .video-player {
    position: relative; background: #0A0A14; margin: 0 16px 16px;
    border-radius: var(--radius-xl); overflow: hidden; aspect-ratio: 16/9;
    display: flex; align-items: center; justify-content: center;
  }
  .video-thumb {
    width: 100%; height: 100%; background: linear-gradient(135deg, #1a3a6b, #C0392B);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .video-play-btn {
    width: 64px; height: 64px; background: rgba(255,255,255,0.92); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; font-size: 24px;
    cursor: pointer; box-shadow: 0 8px 24px rgba(0,0,0,0.4); transition: transform 0.2s;
    border: none;
  }
  .video-play-btn:hover { transform: scale(1.1); }
  .video-title-overlay {
    position: absolute; bottom: 0; right: 0; left: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    padding: 20px 16px 12px; color: white;
  }
  .video-title-overlay .vt-subject { font-size: 11px; color: rgba(255,255,255,0.75); margin-bottom: 4px; }
  .video-title-overlay .vt-title   { font-size: 16px; font-weight: 800; }

  .video-controls-bar {
    display: flex; align-items: center; justify-content: space-between; padding: 8px 16px;
    background: rgba(255,255,255,0.06); margin: 0 16px; border-radius: var(--radius-md);
  }
  .vc-time { color: rgba(255,255,255,0.7); font-size: 12px; font-variant-numeric: tabular-nums; }
  .vc-progress { flex: 1; margin: 0 12px; height: 4px; background: rgba(255,255,255,0.2); border-radius: 2px; }
  .vc-fill { width: 35%; height: 100%; background: var(--gold-light); border-radius: 2px; }
