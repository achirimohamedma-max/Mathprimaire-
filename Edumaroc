<!-- ═══════════════ JAVASCRIPT ═══════════════ -->
<script>
  const screens = ['splash','login','levels','home','subjects','video','exercises','results','parent','schedule','help'];

  function showScreen(id) {
    screens.forEach(s => {
      const el = document.getElementById('screen-' + s);
      if (el) el.classList.toggle('active', s === id);
    });
    window.scrollTo(0, 0);
    // Sync nav buttons
    document.querySelectorAll('#nav-actions .nav-btn').forEach(btn => btn.classList.remove('active-screen'));
  }

  function switchTab(el, tab) {
    document.querySelectorAll('.login-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    ['student','parent','teacher'].forEach(t => {
      const el2 = document.getElementById('tab-' + t);
      if (el2) el2.classList.toggle('hidden', t !== tab);
    });
  }

  function selectLevel(el, num) {
    document.querySelectorAll('.level-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
  }

  function checkAnswer(btn, correct) {
    // Reset all
    document.querySelectorAll('.option-btn').forEach(b => {
      b.classList.remove('correct','wrong');
    });
    btn.classList.add(correct ? 'correct' : 'wrong');
    const fb = document.getElementById('feedback-correct');
    if (fb) {
      fb.className = 'feedback-banner ' + (correct ? 'fb-correct' : 'fb-wrong');
      fb.innerHTML = correct
        ? '<span class="feedback-icon">🌟</span><div class="feedback-text"><div class="fb-title">إجابة صحيحة! أحسنت يا يوسف</div><div class="fb-sub">«التلميذُ» هو الفاعل لأنه من قام بفعل الكتابة</div></div>'
        : '<span class="feedback-icon">💪</span><div class="feedback-text"><div class="fb-title">ليست الإجابة الصحيحة، حاول مرة أخرى</div><div class="fb-sub">تذكّر: الفاعل هو من يقوم بالفعل وليس الفعل نفسه</div></div>';
    }
  }

  function setActiveDay(el) {
    document.querySelectorAll('.day-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
  }
</script>
</body>
